# Copy to .env and adjust.
# GLM_API_KEY=

# --- Hugging Face (Qwen backbone) ---
# "Connection to huggingface.co timed out" is a NETWORK issue, not caused by skipping `pip install -r requirements.txt`.
# Fix ONE of:
#   A) Mirror (pick one):
# TIME_LLM_HF_MIRROR=1
#      (timellm_runtime sets HF_ENDPOINT=https://hf-mirror.com — change mirror URL if you use another)
#   B) Or set HF_ENDPOINT yourself, e.g. HF_ENDPOINT=https://hf-mirror.com
#   C) Or set a local snapshot (no hub at runtime). On this machine a full copy may already exist at:
# TIME_LLM_MODEL_PATH=/root/autodl-tmp/Time-llm-test/D:\huggingface_models/hub/models--Qwen--Qwen2-7B-Instruct/snapshots/f2826a00ceef68f0f2b946d945ecc0477ce4450c
# (Required for Streamlit/timellm_runtime; no auto-discovery — set explicitly or training will fail fast.)
#
# Optional: longer hub timeout (seconds)
# HF_HUB_DOWNLOAD_TIMEOUT=120
#
# Still need transformers>=4.40 for Qwen2 (see requirements.txt).

# TIME_LLM_CHECKPOINT=./checkpoints/timellm_best.pth
# TIME_LLM_ROOT=./timellm-dataset/storage/processed
# TIME_LLM_DATA_PATH=time_llm_data_cleaned.csv

# TIME_LLM_ORCH_DISABLE=1
